# Resend Email API (for sending configuration emails)
# Sign up at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@kairen.xyz

# Public URL (for email links)
NEXT_PUBLIC_BASE_URL=https://kairen.xyz

# Upstash Redis (for rate limiting - optional, falls back to in-memory)
# Sign up at https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Database connection for storing waitlist emails
# DATABASE_URL=postgresql://user:password@localhost:5432/kairen
